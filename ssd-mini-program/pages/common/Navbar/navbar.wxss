.navBar {
  position: fixed;
  z-index: 5;
  top: 0;
  left: 0;
  width: 100vw;
  height: 304rpx;
  overflow: hidden;
  background: #3c2b1f;
}

.nav-bg {
  position: absolute;
  inset: 0;
  display: block;
  width: 100%;
  height: 100%;
}

.nav-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(32, 20, 13, 0.42), rgba(32, 20, 13, 0.18));
}

.person-box {
  position: fixed;
  z-index: 30;
  left: 30rpx;
  display: flex;
  height: 68rpx;
  align-items: center;
}

.person-icon {
  width: 62rpx;
  height: 62rpx;
}

.person-title {
  margin-left: 16rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 42rpx;
}
